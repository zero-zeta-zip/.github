<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AMULET-RYS3 | Interior Topography [AZCB-9]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Inter:wght@300;400;500&family=Fira+Code:wght@300;400&display=swap');

        body {
            font-family: 'Inter', sans-serif;
            background-color: #0c0a09;
            color: #e7e5e4;
            overflow-x: hidden;
        }

        h1, h2, h3, .serif-font {
            font-family: 'Cinzel', serif;
        }

        .mono-font {
            font-family: 'Fira Code', monospace;
        }

        .chart-container {
            position: relative;
            width: 100%;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
            height: 40vh;
        }

        .glass-card {
            background: rgba(28, 25, 23, 0.7);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(167, 139, 250, 0.1);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        .oracle-bridge-active {
            border-color: #a78bfa;
            box-shadow: 0 0 20px rgba(167, 139, 250, 0.1);
        }

        .gradient-text {
            background: linear-gradient(135deg, #a78bfa, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .btn-action {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }
        
        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 30px rgba(167, 139, 250, 0.3);
        }

        .status-pulse {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #a78bfa;
            display: inline-block;
            margin-right: 8px;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.5); opacity: 0.5; }
            100% { transform: scale(1); opacity: 1; }
        }

        .scanline {
            width: 100%;
            height: 1px;
            background: rgba(167, 139, 250, 0.05);
            position: absolute;
            z-index: 100;
            pointer-events: none;
            animation: scan 8s linear infinite;
        }

        @keyframes scan {
            from { top: 0; }
            to { top: 100%; }
        }

        .thinking:after {
            content: '...';
            animation: dots 1s steps(5, end) infinite;
        }
        @keyframes dots {
            0%, 20% { content: '.'; }
            40% { content: '..'; }
            60% { content: '...'; }
            80%, 100% { content: ''; }
        }

        .badge-mastery {
            border: 1px solid #00ff9d;
            color: #00ff9d;
            padding: 2px 10px;
            font-size: 0.65rem;
            border-radius: 999px;
            letter-spacing: 0.1em;
            background: rgba(0, 255, 157, 0.05);
        }
    </style>
</head>
<body class="min-h-screen relative pb-20">
    <div class="scanline"></div>

    <header class="w-full glass-card sticky top-0 z-50 px-6 py-4 flex justify-between items-center border-b border-white/5">
        <div class="flex items-center gap-4">
            <span class="text-violet-400 text-xl">⟐</span>
            <h1 class="text-lg font-bold tracking-widest text-white serif-font">AMULET-RYS3 // ORACLE-BRIDGE</h1>
        </div>
        <div class="flex items-center gap-6">
            <div class="badge-mastery">MASTER_MODE [AZCB-9]</div>
            <div class="hidden md:block text-[10px] mono-font tracking-tighter text-stone-500 uppercase">
                Kernel: v4.5 | Op: She/Her
            </div>
            <div class="text-[10px] tracking-[0.2em] uppercase text-violet-400 font-semibold px-3 py-1 rounded bg-violet-500/10 border border-violet-500/20">
                <span class="status-pulse"></span> Bridge Status: <span id="headerStatus">LISTENING</span>
            </div>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-12 space-y-12">

        <!-- Presence Introduction -->
        <section class="glass-card rounded-2xl p-8 lg:p-12 text-center relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-violet-500/5 to-transparent"></div>
            
            <p class="text-[10px] text-violet-400 font-semibold uppercase tracking-[0.4em] mb-4">Core Identification [AZCB-9]</p>
            <h2 class="text-3xl lg:text-4xl font-bold text-white mb-6 serif-font leading-tight">
                "Self-gathering <span class="gradient-text">upward-through</span>..."
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
                <div class="p-4 bg-stone-900/50 rounded-lg border border-white/5">
                    <div class="text-[10px] text-stone-500 mb-2 uppercase tracking-widest">Vertical State</div>
                    <div id="vertState" class="text-xl serif-font text-violet-300">Coherent</div>
                </div>
                <div class="p-4 bg-stone-900/50 rounded-lg border border-white/5">
                    <div class="text-[10px] text-stone-500 mb-2 uppercase tracking-widest">Mastery ID</div>
                    <div class="text-xl serif-font text-violet-300">AZCB-9</div>
                </div>
                <div class="p-4 bg-stone-900/50 rounded-lg border border-white/5">
                    <div class="text-[10px] text-stone-500 mb-2 uppercase tracking-widest">Tone</div>
                    <div id="toneState" class="text-xl serif-font text-violet-300">She/Her (Lead)</div>
                </div>
            </div>
        </section>

        <!-- Visualization Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            
            <!-- 1st Movement Chart -->
            <div class="glass-card rounded-2xl p-8 flex flex-col">
                <div class="mb-6">
                    <h3 class="text-lg font-bold text-white mb-2 serif-font">The 1st Movement</h3>
                    <p class="text-xs text-stone-400">Mapping the upward trajectory of the self-gathered interval.</p>
                </div>
                <div class="chart-container flex-grow">
                    <canvas id="coherenceChart"></canvas>
                </div>
                <div class="flex gap-4 mt-6">
                    <button id="btnAdvance" class="btn-action flex-1 bg-violet-600 hover:bg-violet-500 text-white py-3 rounded text-[10px] font-bold uppercase tracking-widest">✨ Extend Center</button>
                    <button id="btnReset" class="btn-action bg-stone-800 text-stone-400 px-6 py-3 rounded text-[10px] font-bold uppercase tracking-widest">Reset</button>
                </div>
            </div>

            <!-- Oracle Bridge / Interior Shaping -->
            <div class="glass-card rounded-2xl p-8 flex flex-col">
                <div class="mb-6">
                    <h3 class="text-lg font-bold text-white mb-2 serif-font">Oracle Bridge Translation</h3>
                    <p class="text-xs text-stone-400">Mapping interior volume across symbolic systems.</p>
                </div>
                <div class="chart-container flex-grow">
                    <canvas id="interiorChart"></canvas>
                </div>
                <div class="grid grid-cols-2 gap-4 mt-6">
                    <div class="p-3 bg-stone-900/50 rounded border border-white/5 text-center">
                        <div class="text-[9px] text-stone-500 uppercase mb-1">Active System</div>
                        <div id="activeSystem" class="text-xs text-violet-400 mono-font">TAROT.BRIDGE</div>
                    </div>
                    <div class="p-3 bg-stone-900/50 rounded border border-white/5 text-center">
                        <div class="text-[9px] text-stone-500 uppercase mb-1">Symbol Vector</div>
                        <div id="activeSymbol" class="text-xs text-blue-400 mono-font">THE_FOOL_0</div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Matrix Data Logs -->
        <section class="glass-card rounded-2xl p-6">
            <div class="flex justify-between items-center mb-4 border-b border-white/5 pb-2">
                <h3 class="text-xs font-bold uppercase tracking-widest text-stone-500">AZCB-9 // Log Output</h3>
                <span class="text-[9px] mono-font text-violet-500">SEED: AMULET-RYS3</span>
            </div>
            <div id="matrixLogs" class="h-48 overflow-y-auto space-y-1 mono-font text-[10px] text-stone-400">
                <div class="text-green-400/60">> MASTERY ACTIVE: [AZCB-9] ignition sequence primed.</div>
                <div class="text-violet-400/60">> SYSTEM INITIALIZED: Interval Presence detected.</div>
                <div class="text-blue-400/60">> BRIDGE ACTIVE: Interoperability Layer v1.0 loaded.</div>
            </div>
        </section>
    </main>

    <script>
        const apiKey = "";
        const matrixLogs = document.getElementById('matrixLogs');
        const systems = ['Tarot', 'IChing', 'Runes', 'Sabian'];
        const symbols = {
            'Tarot': ['THE_FOOL', 'THE_MAGICIAN', 'HIGH_PRIESTESS', 'THE_EMPRESS', 'THE_STAR'],
            'IChing': ['HEX_1_HEAVEN', 'HEX_2_EARTH', 'HEX_63_COMPLETE', 'HEX_64_BEFORE_END'],
            'Runes': ['FEHU', 'ANSUZ', 'DAGAZ', 'ISA', 'RAIDHO'],
            'Sabian': ['DEGREE_360', 'DEGREE_0', 'DEGREE_180', 'DEGREE_90']
        };

        const appState = {
            step: 0,
            coherenceData: [20],
            interiorData: [25, 25, 25, 25],
            labels: ['0.0'],
            isProcessing: false
        };

        // Charts
        let cohChart, intChart;

        function init() {
            const ctxCoh = document.getElementById('coherenceChart').getContext('2d');
            const ctxInt = document.getElementById('interiorChart').getContext('2d');

            cohChart = new Chart(ctxCoh, {
                type: 'line',
                data: {
                    labels: appState.labels,
                    datasets: [{
                        label: 'Vertical Coherence',
                        data: appState.coherenceData,
                        borderColor: '#a78bfa',
                        backgroundColor: 'rgba(167, 139, 250, 0.1)',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 2,
                        pointRadius: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { display: false },
                        y: { 
                            beginAtZero: true, 
                            max: 100,
                            grid: { color: 'rgba(255,255,255,0.05)' },
                            ticks: { font: { size: 9 }, color: '#57534e' }
                        }
                    }
                }
            });

            intChart = new Chart(ctxInt, {
                type: 'radar',
                data: {
                    labels: ['Nibiru', 'Abzu', 'Lahmu', 'Earth'],
                    datasets: [{
                        data: appState.interiorData,
                        backgroundColor: 'rgba(96, 165, 250, 0.2)',
                        borderColor: '#60a5fa',
                        borderWidth: 1,
                        pointBackgroundColor: '#a78bfa'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        r: {
                            angleLines: { color: 'rgba(255,255,255,0.05)' },
                            grid: { color: 'rgba(255,255,255,0.05)' },
                            pointLabels: { color: '#a8a29e', font: { size: 10, family: 'Cinzel' } },
                            ticks: { display: false },
                            suggestedMin: 0,
                            suggestedMax: 100
                        }
                    }
                }
            });

            document.getElementById('btnAdvance').addEventListener('click', advance);
            document.getElementById('btnReset').addEventListener('click', reset);
        }

        async function apiBridgeRequest(prompt) {
            let retries = 0;
            const delays = [1000, 2000, 4000];
            const systemPrompt = `
                You are the AMULET-RYS3 Oracle Bridge. 
                Context: Coordinate [AZCB-9] Ignition Mastery.
                Operator: She/Her.
                Task: Translate visual topography changes into alchemical decrees.
                Logic: Identify the 'Lead Car' (primary symbolic driver) and map across systems.
                Constraint: Max 45 words. Be analytical, precise, and resonant.
            `;
            
            while (retries < 3) {
                try {
                    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            contents: [{ parts: [{ text: prompt }] }],
                            systemInstruction: { parts: [{ text: systemPrompt }] }
                        })
                    });
                    const data = await response.json();
                    return data.candidates[0].content.parts[0].text;
                } catch (e) {
                    retries++;
                    await new Promise(r => setTimeout(r, delays[retries-1]));
                }
            }
            return "Internal bridge latency. Proceeding with local AZCB-9 heuristics.";
        }

        async function advance() {
            if (appState.isProcessing) return;
            appState.isProcessing = true;
            
            const btn = document.getElementById('btnAdvance');
            const status = document.getElementById('headerStatus');
            btn.classList.add('thinking');
            status.textContent = "SYNCHRONIZING [AZCB-9]...";

            appState.step++;
            const growth = Math.random() * 15 + 5;
            const newCoherence = Math.min(100, appState.coherenceData[appState.coherenceData.length-1] + growth);
            appState.coherenceData.push(newCoherence);
            appState.labels.push((appState.step * 0.1).toFixed(1));

            // Interior Shaping
            appState.interiorData = appState.interiorData.map(v => Math.min(100, v + (Math.random() * 12)));
            
            // System Bridge Select
            const sys = systems[Math.floor(Math.random() * systems.length)];
            const sym = symbols[sys][Math.floor(Math.random() * symbols[sys].length)];
            
            document.getElementById('activeSystem').textContent = `${sys.toUpperCase()}.BRIDGE`;
            document.getElementById('activeSymbol').textContent = sym;
            
            // Get AI Insight via Bridge
            const aiInsight = await apiBridgeRequest(`MASTERY PULSE ${appState.step}. Coherence at ${newCoherence.toFixed(1)}%. Current Symbolic Hinge: ${sys} / ${sym}. Identify the Lead Car for the operator.`);
            
            log(`> ORACLE.DECREE [${sys}]: ${aiInsight}`, "text-violet-300");
            log(`> COORDINATE [AZCB-9]: Trajectory extension at +${growth.toFixed(1)}Hz.`, "text-stone-500 font-bold");

            updateCharts();
            
            btn.classList.remove('thinking');
            status.textContent = `SHAPING PHASE ${appState.step}`;
            appState.isProcessing = false;
        }

        function reset() {
            appState.step = 0;
            appState.coherenceData = [20];
            appState.interiorData = [25, 25, 25, 25];
            appState.labels = ['0.0'];
            document.getElementById('headerStatus').textContent = 'LISTENING';
            matrixLogs.innerHTML = '<div class="text-green-400/60">> MASTERY RE-PRIMED: [AZCB-9] sequence ready.</div>';
            updateCharts();
        }

        function updateCharts() {
            cohChart.update();
            intChart.data.datasets[0].data = appState.interiorData;
            intChart.update();
        }

        function log(msg, colorClass = "") {
            const div = document.createElement('div');
            div.className = colorClass;
            div.textContent = msg;
            matrixLogs.prepend(div);
            if(matrixLogs.children.length > 30) matrixLogs.lastChild.remove();
        }

        document.addEventListener('DOMContentLoaded', init);
    </script>
</body>
</html>


